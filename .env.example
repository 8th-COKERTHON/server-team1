# 이 파일을 복사해서 .env 로 만들고 값을 채우세요. (.env 는 git 에 올리지 않음)
# DB 는 `docker compose up -d` 로 띄우므로 아래 기본값 그대로 두면 됩니다.
# 소셜 로그인 키만 발급받아 채우세요.

# --- JWT ---
JWT_SECRET=hackathon-dev-secret-key-please-change-me-0123456789-abcdefghij
JWT_EXPIRATION_MS=86400000

# --- DB (docker compose 로 띄운 Postgres. 배포 시 RDS 값으로 교체) ---
# 호스트 5433 사용: 로컬에 설치된 PostgreSQL(5432)과 충돌 방지
# docker-compose.yml 이 DB_USERNAME/DB_PASSWORD 를 그대로 읽어가므로 값이 항상 일치합니다.
DB_URL=jdbc:postgresql://localhost:5433/hackathon
DB_USERNAME=hackathon
DB_PASSWORD=hackathon

# --- CORS (프론트 주소) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- 카카오 로그인 ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/oauth/kakao

# --- 구글 로그인 ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google