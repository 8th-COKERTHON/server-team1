# 로컬은 기본값으로 동작하므로 보통 이 파일을 복사할 필요가 없다.
# 로컬 DB 비밀번호를 기본값과 다르게 쓸 때만 .env 로 복사해서 채운다. (.env 는 git 에 올리지 않음)

# --- DB (docker compose 로 띄운 Postgres. 배포 시 RDS 값으로 교체) ---
# 호스트 5433 사용: 로컬에 설치된 PostgreSQL(5432)과 충돌 방지
# docker-compose.yml 이 DB_USERNAME/DB_PASSWORD 를 그대로 읽어가므로 값이 항상 일치한다.
DB_URL=jdbc:postgresql://localhost:5433/hackathon
DB_USERNAME=hackathon
DB_PASSWORD=hackathon

# --- CORS (프론트 주소) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- AWS S3 (미션 인증 이미지) ---
# 로컬에서 presigned URL 발급만 테스트할 땐 아무 값이나 넣어도 서명은 된다(실제 업로드는 실패).
# 실제 업로드가 되려면 버킷에 PutObject 권한이 있는 IAM 키가 필요하다. (배포는 EC2 .env / GitHub Secrets)
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=dijeok-image-475583545324-ap-northeast-2-an
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
